<div style="font-family: Arial, sans-serif; max-width: 520px; margin: 40px auto;">
  <h2>Restablecer contraseña</h2>
  <p>El enlace expira en 1 hora desde que se envió.</p>

  <form method="post" action="/api/sessions/reset-password/{{token}}">
    <label style="display:block; margin-top: 12px;">
      Nueva contraseña:
      <input
        style="display:block; width: 100%; padding: 10px; margin-top: 6px;"
        type="password"
        name="password"
        required
        minlength="6"
      />
    </label>

    <button style="margin-top: 16px; padding: 12px 18px; background:#2563eb; color:white; border:none; border-radius:6px; cursor:pointer;" type="submit">
      Restablecer contraseña
    </button>
  </form>
</div>

